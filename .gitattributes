# Force LF line endings for all text files
* text=auto eol=lf

# Go source — always LF
*.go text eol=lf
*.mod text eol=lf
*.sum text eol=lf

# Web assets — always LF
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Scripts — always LF
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts — CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary — no conversion
*.exe binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.zip binary
*.tar binary
*.gz binary
